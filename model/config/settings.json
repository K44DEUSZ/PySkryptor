{
  "app": {
    "language": "en",
    "theme": "auto",
    "ui": {
      "show_advanced_settings": false
    },
    "logging": {
      "enabled": true,
      "level": "info"
    }
  },
  "engine": {
    "preferred_device": "auto",
    "precision": "auto",
    "allow_tf32": false,
    "low_cpu_mem_usage": true
  },
  "transcription": {
    "output_format": "srt",
    "download_audio_only": true,
    "url_keep_audio": true,
    "url_audio_ext": "m4a",
    "url_keep_video": false,
    "url_video_ext": "mp4",
    "translate_after_transcription": false
  },
  "translation": {
    "default_source_language": "auto",
    "default_target_language": "auto"
  },
  "model": {
    "transcription_model": {
      "engine_name": "auto",
      "quality_preset": "balanced",
      "text_consistency": true,
      "chunk_length_s": 60,
      "stride_length_s": 5,
      "ignore_warning": false
    },
    "translation_model": {
      "engine_name": "none",
      "max_new_tokens": 256,
      "chunk_max_chars": 1200,
      "quality_preset": "balanced"
    }
  },
  "downloader": {
    "min_video_height": 144,
    "max_video_height": 4320
  },
  "network": {
    "retries": 3,
    "max_bandwidth_kbps": null,
    "concurrent_fragments": 2,
    "http_timeout_s": 30
  }
}