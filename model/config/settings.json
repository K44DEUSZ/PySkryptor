{
  "app": {
    "language": "auto",
    "theme": "auto",
    "logging": {
      "enabled": true,
      "level": "info"
    }
  },
  "engine": {
    "preferred_device": "auto",
    "precision": "auto",
    "allow_tf32": true
  },
  "model": {
    "transcription_model": {
      "engine_name": "auto",
