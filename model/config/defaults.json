{
  "app": {
    "language": "auto",
    "theme": "auto"
  },
  "engine": {
    "preferred_device": "auto",
    "precision": "auto",
    "allow_tf32": true
  },
  "model": {
    "ai_engine_name": "whisper-turbo",
    "chunk_length_s": 60,
    "stride_length_s": 5,
    "ignore_warning": true,
    "default_language": null,
    "low_cpu_mem_usage": true
  },
  "transcription": {
    "mode": "transcribe",
    "target_language": "auto",
    "output_ext": "txt",
    "timestamps_output": false,
    "keep_wav_temp": false,
    "download_audio_only": true,
    "url_keep_audio": false,
    "url_audio_ext": "m4a",
    "url_keep_video": false,
    "url_video_ext": "mp4"
  },
  "downloader": {
    "min_video_height": 144,
    "max_video_height": 4320
  },
  "network": {
    "max_bandwidth_kbps": null,
    "retries": 3,
    "concurrent_fragments": 4,
    "http_timeout_s": 30
  }
}